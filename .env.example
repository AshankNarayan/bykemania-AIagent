# =========================================================
# BykeMania AI Operations Agent - Environment Example
# =========================================================
# Copy this file to .env for local development.
# Never commit your real .env file.
# =========================================================


# ---------------------------------------------------------
# App environment
# ---------------------------------------------------------
# Use development locally.
# Use production on Render.
ENVIRONMENT=development


# ---------------------------------------------------------
# Database settings
# ---------------------------------------------------------
# Local SQLite option:
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///app/storage/agent_logs.sqlite3

# Production PostgreSQL option:
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://username:password@host/database?sslmode=require


# ---------------------------------------------------------
# External API / LLM keys
# ---------------------------------------------------------
# Groq API key used by the LLM router/parser.
GROQ_API_KEY=your_groq_api_key_here

# Private API key required by this FastAPI backend.
# Used in Swagger Authorize or x-api-key header.
APP_API_KEY=your_private_app_api_key_here

# Private BykeMania backend/fleet API URL.
# Do not expose the real value publicly.
SIR_API_URL=your_private_backend_api_url_here


# ---------------------------------------------------------
# Scheduler settings
# ---------------------------------------------------------
# Keep false until production alert volume is confirmed.
ALERT_SCHEDULER_ENABLED=false

# Scheduler interval in minutes.
ALERT_SCHEDULER_INTERVAL_MINUTES=120

# Whether scheduler should run immediately on app startup.
ALERT_SCHEDULER_RUN_ON_STARTUP=false

# Prevent duplicate/frequent alert runs.
ALERT_RUN_COOLDOWN_MINUTES=60


# ---------------------------------------------------------
# Timeout settings
# ---------------------------------------------------------
# Prevent slow LLM/backend calls from hanging the API.
CHAT_TIMEOUT_SECONDS=60
ALERT_RUN_TIMEOUT_SECONDS=120
SCHEDULER_MANUAL_RUN_TIMEOUT_SECONDS=120


# ---------------------------------------------------------
# Rate limit settings
# ---------------------------------------------------------
# Basic in-memory rate limiting.
CHAT_RATE_LIMIT_PER_MINUTE=30
ALERT_RUN_RATE_LIMIT_PER_HOUR=6
SCHEDULER_RUN_RATE_LIMIT_PER_HOUR=6


# ---------------------------------------------------------
# CORS settings
# ---------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# For local development:
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# For Render production, use something like:
# CORS_ORIGINS=

# Later, when frontend is deployed, add frontend URL:
# CORS_ORIGINS=https://your-frontend-domain.com,

# ---------------------------------------------------------
# Smoke test settings
# ---------------------------------------------------------
# Optional. Used only by scripts/smoke_test.py.
# If not set, the script uses APP_API_KEY and http://127.0.0.1:8000.
SMOKE_TEST_BASE_URL=http://127.0.0.1:8000
SMOKE_TEST_API_KEY=your_private_app_api_key_here