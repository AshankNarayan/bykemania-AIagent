# ==============================
# BykeMania AI Agent Environment
# ==============================

# Groq API key for LLM-based query parsing / response support
GROQ_API_KEY=your_groq_api_key_here

# Internal API key for protecting backend endpoints
# Send this in request headers as:
# x-api-key: your_app_api_key_here
APP_API_KEY=your_app_api_key_here

# Private optimized backend API endpoint
# Do not commit the real endpoint in public repositories
SIR_API_URL=your_private_optimized_api_url_here

# Scheduler settings
ALERT_SCHEDULER_ENABLED=false
ALERT_SCHEDULER_INTERVAL_MINUTES=120
ALERT_SCHEDULER_RUN_ON_STARTUP=false

# Cooldown protection to prevent duplicate/frequent alert runs
ALERT_RUN_COOLDOWN_MINUTES=60

# Database settings
# Local development:
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///app/storage/agent_logs.sqlite3

# For future cloud PostgreSQL:
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# CORS settings
# Comma-separated list of allowed frontend origins.
# Example:
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
CORS_ORIGINS=https://bykemania-agent-api.onrender.com